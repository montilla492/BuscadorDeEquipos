rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn(); } // Relaxed for AI Studio demo
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- User Rules ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'displayName', 'reputation']) &&
               data.displayName is string && data.displayName.size() <= 64 &&
               data.reputation is number;
      }

      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() && isValidUser(incoming());
      
      allow update: if isSignedIn() && (
        // Action: Self-Edit
        (userId == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'updatedAt', 'games']) &&
         incoming().get('reputation', 0) == existing().get('reputation', 0)) ||
        // Action: Receive Reputation (From others)
        (userId != request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly(['reputation', 'updatedAt']) &&
         (incoming().reputation == (existing().get('reputation', 0) + 1) || 
          incoming().reputation == (existing().get('reputation', 0) - 1)))
      );
    }

    // --- Squad Rules ---
    match /squads/{squadId} {
      function isValidSquad(data) {
        return data.keys().hasAll(['leaderId', 'gameId', 'title', 'maxMembers', 'status', 'memberIds']) &&
               data.leaderId == request.auth.uid &&
               data.title is string && data.title.size() <= 64 &&
               data.maxMembers is int && data.maxMembers >= 1 && data.maxMembers <= 100 &&
               data.status in ['searching', 'in-game', 'closed'];
      }

      allow read: if true; // Public read for dashboard
      
      allow create: if isVerified() && isValidSquad(incoming()) && 
                       incoming().memberIds.size() == 1 &&
                       incoming().memberIds[0] == request.auth.uid;
      
      // Action: Update Squad (Leader or Membership logic)
      allow update: if isVerified() && (
        // Action: Update Metadata (Leader only)
        (existing().leaderId == request.auth.uid &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'title', 'description', 'rankLimit', 'vibe'])) ||
        // Action: Join (Add self)
        (incoming().diff(existing()).affectedKeys().hasOnly(['memberIds', 'members']) &&
         incoming().memberIds.size() > existing().memberIds.size() &&
         incoming().memberIds.size() <= existing().maxMembers &&
         incoming().memberIds.hasAll(existing().memberIds) &&
         request.auth.uid in incoming().memberIds &&
         !(request.auth.uid in existing().memberIds)) ||
        // Action: Leave (Remove self)
        (incoming().diff(existing()).affectedKeys().hasOnly(['memberIds', 'members']) &&
         incoming().memberIds.size() < existing().memberIds.size() &&
         request.auth.uid in existing().memberIds &&
         !(request.auth.uid in incoming().memberIds))
      );
      
      allow delete: if isVerified() && existing().leaderId == request.auth.uid;

      // --- Subcollection: Messages ---
      match /messages/{msgId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/squads/$(squadId)).data.memberIds.hasAny([request.auth.uid]));
        allow create: if isVerified() && 
                         incoming().squadId == squadId &&
                         incoming().senderId == request.auth.uid &&
                         get(/databases/$(database)/documents/squads/$(squadId)).data.memberIds.hasAny([request.auth.uid]);
      }
    }

    // --- Invitation Rules ---
    match /invitations/{invId} {
      function isValidInvite(data) {
        return data.keys().hasAll(['squadId', 'fromId', 'toId', 'type', 'status']) &&
               (data.fromId == request.auth.uid || data.toId == request.auth.uid) &&
               data.status in ['pending', 'accepted', 'rejected'];
      }

      allow read: if isSignedIn(); 
      
      allow create: if isVerified() && isValidInvite(incoming()) && 
                       incoming().fromId == request.auth.uid &&
                       incoming().status == 'pending';
      
      allow update: if isVerified() && (
        // Receiver accepts/rejects
        (existing().toId == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      );
    }

    // --- Notification Rules ---
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isVerified() && existing().userId == request.auth.uid && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isVerified() && existing().userId == request.auth.uid;
    }
  }
}
